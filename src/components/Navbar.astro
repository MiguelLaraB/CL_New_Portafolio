---
const navItems = [
  { label: 'Inicio', route: '/home' },
  { label: 'Servicios', route: '/home#servicios' },
  { label: 'Proyectos', route: '/home#portafolio' },
  { label: 'Proceso', route: '/home#proceso' },
  { label: 'Contacto', route: '/home#contacto' },
];
---

<nav class="navbar">
  <div class="navbar-container">
    <a href="/home" class="navbar-logo logo-img" aria-label="Código Local"></a>
    <div class="navbar-items desktop-only">
      {navItems.map((item) => (
        <a href={item.route} class="nav-item">{item.label}</a>
      ))}
      <a href="/home#contacto" class="btn btn-primary nav-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Contáctanos
      </a>
    </div>
    <button class="mobile-menu-button" id="menuToggle" aria-label="Menú">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu-header">
      <div class="navbar-logo logo-img small"></div>
      <button class="close-button" id="closeMenu" aria-label="Cerrar menú">✕</button>
    </div>
    <div class="mobile-menu-items">
      {navItems.map((item) => (
        <a href={item.route} class="mobile-nav-item">{item.label}</a>
      ))}
      <a href="/home#contacto" class="btn btn-primary" style="margin-top: 1rem; justify-content: center;">
        Contáctanos
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(10px);
    padding: 0 2rem;
    z-index: 1000;
    height: var(--nav-height);
    border-bottom: 1px solid var(--border);
  }
  .navbar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    height: 100%;
  }
  .navbar-logo {
    display: flex;
    align-items: center;
  }
  .logo-img {
    height: 55px;
    width: auto;
    object-fit: contain;
    background-image: url('/logo_cl_texto.png');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    min-width: 140px;
  }
  .navbar-items {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .nav-item {
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    font-weight: 500;
    font-size: 0.9rem;
    font-family: 'Inter', sans-serif;
  }
  .nav-item:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.05);
  }
  .nav-cta {
    padding: 0.5rem 1.2rem;
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }
  .mobile-menu-button {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .mobile-menu {
    position: fixed;
    top: 0;
    right: -100%;
    width: 80%;
    max-width: 320px;
    height: 100vh;
    background: var(--bg-secondary);
    z-index: 2000;
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -5px 0 25px rgba(0, 0, 0, 0.5);
    border-left: 1px solid var(--border);
  }
  .mobile-menu.open { right: 0; }
  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .logo-img.small {
    height: 40px;
    min-width: 100px;
  }
  .close-button {
    background: none;
    border: none;
    color: white;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.5rem;
  }
  .mobile-menu-items {
    display: flex;
    flex-direction: column;
    padding: 2rem 1.5rem;
    gap: 0.5rem;
  }
  .mobile-nav-item {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-family: 'Inter', sans-serif;
  }
  .mobile-nav-item:hover { color: var(--text-primary); }

  @media (max-width: 768px) {
    .navbar { padding: 0 1rem; }
    .desktop-only { display: none !important; }
    .mobile-menu-button { display: block; }
    .logo-img { height: 45px; min-width: 110px; }
  }
</style>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  const closeMenu = document.getElementById('closeMenu');

  menuToggle.addEventListener('click', () => mobileMenu.classList.add('open'));
  closeMenu.addEventListener('click', () => mobileMenu.classList.remove('open'));
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });
</script>
