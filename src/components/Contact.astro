---
const contacts = [
  {
    label: "WhatsApp",
    icon: "whatsapp",
    link: "https://wa.me/522721653130",
    detail: "Respuesta rápida",
  },
  {
    label: "Correo Electrónico",
    icon: "email",
    link: "mailto:codigolocal12@gmail.com",
    detail: "codigolocal12@gmail.com",
  },
  {
    label: "Instagram",
    icon: "instagram",
    link: "https://www.instagram.com/codigo.local/",
    detail: "@codigo.local",
  },
  {
    label: "Facebook",
    icon: "facebook",
    link: "https://www.facebook.com/profile.php?id=61588202047531",
    detail: "Código Local",
  },
];
---

<section class="section" id="contacto">
  <div class="container">
    <div class="contact-intro">
      <div class="cta-glow"></div>
      <h2 class="cta-title">¿Listo para digitalizar tu negocio?</h2>
      <p class="cta-desc">
        ¡Contáctanos!, elige el canal de tu preferencia y te responderemos a la
        brevedad.
      </p>
    </div>
    <div class="contact-grid">
      {
        contacts.map((c) => (
          <a
            href={c.link}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-card"
          >
            <div class="contact-icon">
              {c.icon === "whatsapp" && (
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              )}
              {c.icon === "email" && (
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="M22 4l-10 8L2 4" />
                </svg>
              )}
              {c.icon === "instagram" && (
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                </svg>
              )}
              {c.icon === "facebook" && (
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
              )}
            </div>
            <div class="contact-info">
              <span class="contact-label">{c.label}</span>
              <span class="contact-detail">{c.detail}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-intro {
    text-align: center;
    margin-bottom: 2.5rem;
    position: relative;
  }
  .cta-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(88, 166, 255, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .cta-title {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    font-family: "Oswald", sans-serif;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .cta-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 550px;
    margin: 0 auto;
    font-family: "Inter", sans-serif;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: all 0.3s ease;
    text-align: center;
  }
  .contact-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 8px 30px rgba(88, 166, 255, 0.1);
  }
  .contact-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(88, 166, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    transition: all 0.3s ease;
  }
  .contact-card:hover .contact-icon {
    background: var(--accent);
    color: white;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .contact-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
    font-family: "Inter", sans-serif;
  }
  .contact-detail {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: "Inter", sans-serif;
  }

  @media (max-width: 768px) {
    .cta-title {
      font-size: 1.8rem;
    }
    .cta-desc {
      font-size: 1rem;
    }
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
