---
import Layout from '../layouts/Layout.astro';


const posSystems = [
  {
    title: 'Sistema POS y gestión de inventario',
    image: '/pos.png',
    link: 'https://cl-pos-demo.vercel.app/sales',
  },
];
---

<Layout>
  <div class="web-pages-container">
    <div class="demo-note">
      <p class="note-header">¿Necesitas un sistema para dispositivos móviles?</p>
      <p class="note-text">Podemos desarrollar una solución adaptada a tu negocio.</p>
    </div>
    <div class="pages-grid">
      {posSystems.map((system) => (
        <a href={system.link} target="_blank" rel="noopener noreferrer" class="page-card">
          <div class="card-image-container">
            <img src={system.image} alt={system.title} class="card-image" />
          </div>
          <h3 class="card-title">{system.title}</h3>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .web-pages-container {
    min-height: 100vh;
    padding: 2rem;
    padding-top: 150px;
    background-color: #0D1117;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .demo-note {
    max-width: 1400px;
    width: 100%;
    margin-bottom: 2rem;
    padding: 0 2.5rem;
    animation: fadeInDown 0.8s ease-out;
  }
  .note-header {
    color: #58a6ff;
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
  }
  .note-text {
    color: #c9d1d9;
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 900px;
  }
  .pages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    max-width: 1400px;
    margin: 0 auto;
    background-color: #3a3a3a;
    padding: 2.5rem;
    border-radius: 16px;
    animation: fadeInDown 0.8s ease-out;
  }
  .page-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .page-card:hover {
    transform: translateY(-5px);
  }
  .card-image-container {
    overflow: hidden;
    border-radius: 12px;
    background-color: #2a2a2a;
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .card-image:hover {
    transform: scale(1.05);
  }
  .card-title {
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    padding: 0 0.5rem;
    text-align: center;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1200px) {
    .pages-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      padding: 2rem;
    }
    .page-card { gap: 1.2rem; }
  }
  @media (max-width: 768px) {
    .web-pages-container { padding: 1.5rem; padding-top: 110px; }
    .pages-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .demo-note { padding: 0 1.5rem; }
    .note-header { font-size: 1.2rem; }
    .note-text { font-size: 1rem; }
    .card-image-container { aspect-ratio: 4 / 3; }
    .card-title { font-size: 1rem; }
  }
  @media (max-width: 480px) {
    .web-pages-container { padding: 1rem; padding-top: 100px; }
    .pages-grid { grid-template-columns: 1fr; gap: 1.2rem; padding: 1.2rem; }
    .demo-note { padding: 0 1.2rem; }
    .note-header { font-size: 1.1rem; }
    .note-text { font-size: 0.9rem; }
    .card-image-container { aspect-ratio: 16 / 9; }
    .card-title { font-size: 0.95rem; }
  }
</style>
